generator client {
  provider     = "prisma-client"
  output       = "../generated"
  moduleFormat = "esm"
  runtime      = "bun"
}

datasource db {
  provider = "postgresql"
}

enum EventType {
  FREE
  PAID
}

enum EventMode {
  ONLINE
  OFFLINE
}

// Event Modal Ready
model Event {
  id          String     @id @default(cuid())
  name        String
  timezone    DateTime
  type        EventType
  mode        EventMode
  description String
  startDate   DateTime
  endDate     DateTime
  location    String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  price       Float?
  tickets     Ticket[] 
  passes      Pass[]
  attendees   Attendee[]
}
// Ticket model Ready
model Ticket {
  id        String    @id @default(cuid())
  eventId   String
  event     Event     @relation(fields: [eventId], references: [id])
  price     Float
  quantity  Int @default(1)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  payments  Payment[]
  qrCode    QRCode?
  maxqantity Int
}
// Attendee Modal Ready
model Attendee {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  checkIns CheckIn[]
  passes   Pass[]
}

// Pass modal Ready
model Pass {
  id         String   @id @default(cuid())
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id])
  attendeeId String
  attendee   Attendee @relation(fields: [attendeeId], references: [id])
  type       String
  status     String   @default("ACTIVE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  qrCode QRCode
}
// checkin modal ready
model CheckIn {
  id         String   @id @default(cuid())
  attendeeId String
  attendee   Attendee @relation(fields: [attendeeId], references: [id])
  timestamp  DateTime @default(now())
  method     String
}
// Payment modal Ready
model Payment {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  amount    Float
  status    String   @default("PENDING")
  provider  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
// Qr Code Modal Ready
model QRCode {
  id        String   @id @default(cuid())
  code      String   @unique
  ticketId  String?  @unique
  ticket    Ticket?  @relation(fields: [ticketId], references: [id])
  passId    String?  @unique
  pass      Pass?    @relation(fields: [passId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
