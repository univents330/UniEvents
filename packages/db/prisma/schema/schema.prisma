generator client {
  provider     = "prisma-client"
  output       = "../generated"
  moduleFormat = "esm"
  runtime      = "bun"
}

datasource db {
  provider = "postgresql"
}

enum EventType {
  FREE
  PAID
}

enum EventMode {
  ONLINE
  OFFLINE
}
enum EventVisibility {
  PUBLIC
  PRIVATE
}

enum UserRole {
  ADMIN
  HOST
  USER
}

enum AuthProvider {
  AUTH0
  EMAIL
}

enum PaymentGateway {
  RAZORPAY
}

enum PassStatus {
  ACTIVE
  USED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  role         UserRole @default(USER)
  authProvider AuthProvider @default(AUTH0)
  authSubject  String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hostedEvents Event[]
}

// Event Modal Ready
model Event {
  id          String     @id @default(cuid())
  name        String
  timezone    DateTime
  coverurl    String 
  thumbnail   String
  venuename   String
  address     String
  latitude    String
  longitude  String
  type        EventType
  mode        EventMode
  description String
  startDate   DateTime
  endDate     DateTime
  location    String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  price       Float?
  tickets     Ticket[] 
  passes      Pass[]
  visibility  EventVisibility
  attendees   Attendee[]
  hostId      String?
  host        User?      @relation(fields: [hostId], references: [id])
  coupons     Coupon[]
}
// Ticket model Ready
model Ticket {
  id        String    @id @default(cuid())
  eventId   String
  event     Event     @relation(fields: [eventId], references: [id])
  price     Float
  quantity  Int @default(1)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  payments  Payment[]
  qrCode    QRCode?
  maxqantity Int
}
// Attendee Modal Ready
model Attendee {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  checkIns CheckIn[]
  passes   Pass[]
}

// Pass modal Ready
model Pass {
  id         String   @id @default(cuid())
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id])
  attendeeId String
  attendee   Attendee @relation(fields: [attendeeId], references: [id])
  type       String
  status     PassStatus   @default(ACTIVE)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  qrCode     QRCode?
  checkIns   CheckIn[]
}
// checkin modal ready
model CheckIn {
  id         String   @id @default(cuid())
  attendeeId String
  attendee   Attendee @relation(fields: [attendeeId], references: [id])
  passId     String
  pass       Pass     @relation(fields: [passId], references: [id])
  timestamp  DateTime @default(now())
  method     String

  @@unique([passId])
}
// Payment modal Ready
model Payment {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  couponId  String?
  coupon    Coupon?  @relation(fields: [couponId], references: [id])
  amount    Float
  status    PaymentStatus @default(PENDING)
  gateway   PaymentGateway?
  transactionId String? @unique
  currency  String   @default("INR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  description String?
  discountPct Int
  isActive    Boolean  @default(true)
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  payments    Payment[]
}
// QrCode Modal Ready
model QRCode {
  id        String   @id @default(cuid())
  code      String   @unique
  ticketId  String  @unique
  ticket    Ticket  @relation(fields: [ticketId], references: [id])
  passId    String  @unique
  pass      Pass    @relation(fields: [passId], references: [id])
  isUsed    Boolean @default(false)
  usedAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}