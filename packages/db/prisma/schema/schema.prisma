generator client {
  provider     = "prisma-client"
  output       = "../generated"
  moduleFormat = "esm"
  runtime      = "bun"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  USER
}

enum EventType {
  FREE
  PAID
}

enum EventMode {
  ONLINE
  OFFLINE
}

enum EventVisibility {
  PUBLIC
  PRIVATE
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum PassStatus {
  ACTIVE
  USED
  CANCELLED
}

enum CheckInMethod {
  QR_SCAN
  MANUAL
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentGateway {
  RAZORPAY
}

enum NotificationType {
  EVENT_CREATED
  EVENT_UPDATED
  EVENT_CANCELLED
  EVENT_REMINDER
  ORDER_CONFIRMED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  CHECK_IN_CONFIRMED
  PASS_ISSUED
}

enum NotificationStatus {
  UNREAD
  READ
}

// ─────────────────────────────────────────────
// AUTH MODELS (BetterAuth compatible)
// ─────────────────────────────────────────────

model User {
  id            String   @id @default(ulid())
  name          String?
  email         String
  emailVerified Boolean  @default(false)
  image         String?
  role          UserRole @default(USER) // ADMIN (platform admin) or USER (all other users)
  isHost        Boolean  @default(false) // set true when user creates first event
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]
  attendees     Attendee[]
  hostedEvents  Event[]  @relation("hostedEvents")
  notifications Notification[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id @default(ulid())
  expiresAt DateTime
  token     String   // stores the hashed refresh token
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(ulid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@unique([providerId, accountId])
  @@map("account")
}

// identifier = email or phone, no userId required — supports pre-signup verification
model Verification {
  id         String   @id
  identifier String 
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ─────────────────────────────────────────────
// EVENT
// ─────────────────────────────────────────────

model Event {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  userId      String?
  user        User?           @relation("hostedEvents", fields: [userId], references: [id], onDelete: SetNull)

  // Media
  coverUrl    String
  thumbnail   String?

  // Venue
  venueName   String?
  address     String?
  latitude    String?
  longitude   String?

  // Scheduling — timezone as IANA string e.g. "Asia/Kolkata"
  timezone    String          @default("UTC")
  startDate   DateTime
  endDate     DateTime

  // Classification
  type        EventType
  mode        EventMode       @default(OFFLINE)
  visibility  EventVisibility @default(PUBLIC)
  status      EventStatus     @default(DRAFT)
  isApproved  Boolean         @default(false)

  description String

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  ticketTiers TicketTier[]
  tickets     Ticket[]
  passes      Pass[]
  attendees   Attendee[]
  orders      Order[]
  notifications Notification[]

  @@index([slug])
  @@index([userId])
  @@index([startDate])
  @@index([status])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// TICKET TIER  (the "type" of ticket e.g. GA, VIP)
// ─────────────────────────────────────────────

model TicketTier {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  name        String           // e.g. "General Admission", "VIP"
  description String?
  price       Int              // in paise. 0 for free tiers
  quantity    Int              // total available
  soldCount   Int      @default(0)

  salesStart  DateTime?
  salesEnd    DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tickets     Ticket[]

  @@index([eventId])
}

// ─────────────────────────────────────────────
// TICKET  (one issued ticket instance per attendee)
// ─────────────────────────────────────────────

model Ticket {
  id           String     @id @default(cuid())
  orderId      String
  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  eventId      String
  event        Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tierId       String
  tier         TicketTier @relation(fields: [tierId], references: [id], onDelete: Restrict)

  // Snapshot price in paise at time of purchase
  pricePaid    Int

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  pass         Pass?

  @@index([orderId])
  @@index([eventId])
  @@index([tierId])
}

// ─────────────────────────────────────────────
// ATTENDEE
// ─────────────────────────────────────────────
// Guest Checkout: userId is null for guest purchases (email only)
// Account Linking: When user signs up with same email, link Attendee.userId to User.id

model Attendee {
  id        String   @id @default(cuid())
  userId    String?  // null for guest checkouts, linked when user creates account
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  name      String
  email     String
  phone     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  checkIns  CheckIn[]
  passes    Pass[]
  orders    Order[]

  @@unique([eventId, email])
  @@index([userId])
  @@index([eventId])
  @@index([email]) // for account linking when guests sign up
}

// ─────────────────────────────────────────────
// ORDER
// ─────────────────────────────────────────────

model Order {
  id          String      @id @default(cuid())
  attendeeId  String
  attendee    Attendee    @relation(fields: [attendeeId], references: [id], onDelete: Cascade)
  eventId     String
  event       Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)

  status      OrderStatus @default(PENDING)
  totalAmount Int         // total order amount in paise

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tickets     Ticket[]
  payment     Payment?
  notifications Notification[]

  @@index([attendeeId])
  @@index([eventId])
}

// ─────────────────────────────────────────────
// PASS  (entry pass per ticket, QR generated client-side)
// ─────────────────────────────────────────────

model Pass {
  id         String     @id @default(cuid())
  eventId    String
  event      Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendeeId String
  attendee   Attendee   @relation(fields: [attendeeId], references: [id], onDelete: Cascade)
  ticketId   String     @unique
  ticket     Ticket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  status     PassStatus @default(ACTIVE)
  code       String     @unique // QR code for scanning

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([eventId])
  @@index([attendeeId])
  @@index([code])
}

// ─────────────────────────────────────────────
// CHECK-IN
// ─────────────────────────────────────────────

model CheckIn {
  id         String        @id @default(cuid())
  attendeeId String
  attendee   Attendee      @relation(fields: [attendeeId], references: [id], onDelete: Cascade)
  eventId    String

  timestamp  DateTime      @default(now())
  method     CheckInMethod @default(QR_SCAN)

  @@unique([attendeeId, eventId])
  @@index([attendeeId])
  @@index([eventId])
  @@index([timestamp])
}

// ─────────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────────

model Payment {
  id            String         @id @default(cuid())
  orderId       String         @unique
  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  amount        Int            // in paise
  currency      String         @default("INR")

  gateway       PaymentGateway
  transactionId String?        @unique
  gatewayMeta   Json?          // webhook payload for audit

  status        PaymentStatus  @default(PENDING)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([orderId])
  @@index([transactionId])
}

// ─────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────

model Notification {
  id        String             @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  status    NotificationStatus @default(UNREAD)
  readAt    DateTime?
  userId    String?
  user      User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId   String?
  event     Event?             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orderId   String?
  order     Order?             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt DateTime           @default(now())

  @@index([userId])
  @@index([eventId])
  @@index([orderId])
  @@index([status])
  @@index([createdAt])
}
