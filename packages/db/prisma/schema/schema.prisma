generator client {
  provider     = "prisma-client"
  output       = "../generated"
  moduleFormat = "esm"
  runtime      = "bun"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  HOST
  USER
}

enum EventType {
  FREE
  PAID
}

enum EventMode {
  ONLINE
  OFFLINE
}

enum EventVisibility {
  PUBLIC
  PRIVATE
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum PassType {
  GENERAL
  VIP
  BACKSTAGE
  SPEAKER
}

enum PassStatus {
  ACTIVE
  USED
  CANCELLED
}

enum CheckInMethod {
  QR_SCAN
  MANUAL
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentGateway {
  RAZORPAY
}

// ─────────────────────────────────────────────
// AUTH MODELS (BetterAuth compatible)
// ─────────────────────────────────────────────

model User {
  id            String   @id @default(ulid())
  name          String?
  email         String
  emailVerified Boolean  @default(false)
  image         String?
  role          UserRole @default(USER)
  skills        String[] @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]
  attendees     Attendee[]
  hostedEvents  Event[]  @relation("hostedEvents")

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id @default(ulid())
  expiresAt DateTime
  token     String   // stores the hashed refresh token
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(ulid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@unique([providerId, accountId])
  @@map("account")
}

// identifier = email or phone, no userId required — supports pre-signup verification
model Verification {
  id         String   @id
  identifier String 
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ─────────────────────────────────────────────
// EVENT
// ─────────────────────────────────────────────

model Event {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  userId      String?
  user        User?           @relation("hostedEvents", fields: [userId], references: [id], onDelete: SetNull)

  // Media
  coverUrl    String
  thumbnail   String

  // Venue
  venueName   String
  address     String
  latitude    String
  longitude   String

  // Scheduling — timezone as IANA string e.g. "Asia/Kolkata"
  timezone    String
  startDate   DateTime
  endDate     DateTime

  // Classification
  type        EventType
  mode        EventMode
  visibility  EventVisibility
  status      EventStatus     @default(DRAFT)

  description String

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  ticketTiers TicketTier[]
  tickets     Ticket[]
  passes      Pass[]
  attendees   Attendee[]
  orders      Order[]

  @@index([slug])
  @@index([userId])
  @@index([startDate])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// TICKET TIER  (the "type" of ticket e.g. GA, VIP)
// ─────────────────────────────────────────────

model TicketTier {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  name        String           // e.g. "General Admission", "VIP"
  description String?
  price       Int              // in minor units (paise / cents). 0 for free tiers
  maxQuantity Int              // total available
  soldCount   Int      @default(0) // maintained via application logic or triggers

  salesStart  DateTime?
  salesEnd    DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tickets     Ticket[]

  @@index([eventId])
}

// ─────────────────────────────────────────────
// TICKET  (one issued ticket instance per attendee)
// ─────────────────────────────────────────────

model Ticket {
  id           String     @id @default(cuid())
  orderId      String
  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  eventId      String
  event        Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tierId       String
  tier         TicketTier @relation(fields: [tierId], references: [id], onDelete: Restrict)

  // Snapshot price at time of purchase — tier price may change later
  pricePaid    Int

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  pass         Pass?

  @@index([orderId])
  @@index([eventId])
  @@index([tierId])
}

// ─────────────────────────────────────────────
// ATTENDEE
// ─────────────────────────────────────────────

model Attendee {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  name      String
  email     String
  phone     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  checkIns  CheckIn[]
  passes    Pass[]
  orders    Order[]

  @@unique([eventId, email])
  @@index([userId])
  @@index([eventId])
}

// ─────────────────────────────────────────────
// ORDER
// ─────────────────────────────────────────────

model Order {
  id          String      @id @default(cuid())
  attendeeId  String
  attendee    Attendee    @relation(fields: [attendeeId], references: [id], onDelete: Cascade)
  eventId     String
  event       Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)

  status      OrderStatus @default(PENDING)

  // Soft delete — preserves records for accounting/audit
  deletedAt   DateTime?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tickets     Ticket[]
  payment     Payment?

  @@index([attendeeId])
  @@index([eventId])
}

// ─────────────────────────────────────────────
// PASS  (entry pass per ticket, QR generated client-side)
// ─────────────────────────────────────────────

model Pass {
  id         String     @id @default(cuid())
  eventId    String
  event      Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendeeId String
  attendee   Attendee   @relation(fields: [attendeeId], references: [id], onDelete: Cascade)
  ticketId   String     @unique  // 1-to-1: one pass per ticket
  ticket     Ticket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  type       PassType   @default(GENERAL)
  status     PassStatus @default(ACTIVE)

  // Unique scannable code — generated client-side, stored for server-side validation
  code       String     @unique

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([eventId])
  @@index([attendeeId])
  @@index([code])
}

// ─────────────────────────────────────────────
// CHECK-IN
// ─────────────────────────────────────────────

model CheckIn {
  id         String        @id @default(cuid())
  attendeeId String
  attendee   Attendee      @relation(fields: [attendeeId], references: [id], onDelete: Cascade)
  eventId    String        // direct index for event-level check-in dashboards

  timestamp  DateTime      @default(now())
  method     CheckInMethod

  @@unique([attendeeId, eventId])
  @@index([attendeeId])
  @@index([eventId])
  @@index([timestamp])
}

// ─────────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────────

model Payment {
  id            String         @id @default(cuid())
  orderId       String         @unique
  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  amount        Int            // in minor units (paise / cents)
  currency      String         @default("INR")

  gateway       PaymentGateway
  transactionId String?        @unique // provider's transaction/payment ID
  gatewayMeta   Json?          // raw webhook payload or provider response for audit

  status        PaymentStatus  @default(PENDING)

  // Soft delete — never hard-delete payment records
  deletedAt     DateTime?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([orderId])
  @@index([transactionId])
}
