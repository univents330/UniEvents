{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "nodemon -w src -w ../../packages -e ts,json --exec \"bun run src/index.ts\"",
		"start": "bun run dist/index.mjs"
	},
	"dependencies": {
		"@better-auth/infra": "^0.1.14",
		"@better-auth/prisma-adapter": "^1.4.0",
		"@voltaze/db": "workspace:*",
		"@voltaze/env": "workspace:*",
		"@voltaze/schema": "workspace:*",
		"better-auth": "^1.4.0",
		"cors": "^2.8.5",
		"dotenv": "catalog:",
		"express": "^5.1.0",
		"express-rate-limit": "^8.3.2",
		"helmet": "^8.1.0",
		"razorpay": "^2.9.6",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@types/bun": "catalog:",
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.1",
		"@voltaze/config": "workspace:*",
		"nodemon": "^3.1.14",
		"tsdown": "^0.16.5",
		"typescript": "^6"
	}
}
