{
	"name": "@unievent/server",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"lint": "biome check .",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "nodemon -w src -w ../../packages -e ts,json --exec \"bun run src/index.ts\"",
		"start": "bun run dist/index.mjs"
	},
	"dependencies": {
		"@better-auth/infra": "^0.1.14",
		"@unievent/db": "workspace:*",
		"@unievent/env": "workspace:*",
		"@unievent/schema": "workspace:*",
		"better-auth": "^1.4.0",
		"cors": "^2.8.5",
		"dotenv": "catalog:",
		"express": "^5.1.0",
		"express-rate-limit": "^8.3.2",
		"handlebars": "^4.7.9",
		"helmet": "^8.1.0",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"puppeteer": "^24.42.0",
		"qrcode": "^1.5.4",
		"razorpay": "^2.9.6",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@types/bun": "catalog:",
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.1",
		"@types/qrcode": "^1.5.6",
		"@unievent/config": "workspace:*",
		"nodemon": "^3.1.14",
		"tsdown": "^0.16.5",
		"typescript": "^6"
	}
}
