{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "bun run --hot src/index.ts",
		"start": "bun run dist/index.mjs"
	},
	"dependencies": {
		"@voltaze/db": "workspace:*",
		"@voltaze/env": "workspace:*",
		"@voltaze/schema": "workspace:*",
		"better-auth": "^1.5.6",
		"cors": "^2.8.5",
		"dotenv": "catalog:",
		"express": "^5.1.0",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@voltaze/config": "workspace:*",
		"@types/bun": "catalog:",
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.1",
		"tsdown": "^0.16.5",
		"typescript": "^5"
	}
}
