FROM oven/bun:1.3.6 AS base

# --- Prune Stage ---
FROM base AS pruner
WORKDIR /app
RUN bun add -g turbo
COPY . .
RUN turbo prune @unievent/server --docker

# --- Installer Stage ---
FROM base AS installer
WORKDIR /app

COPY --from=pruner /app/out/json/ .
COPY --from=pruner /app/out/bun.lock ./bun.lock
ENV PRISMA_SKIP_POSTINSTALL_GENERATE=1
RUN bun install --frozen-lockfile

# --- Builder Stage ---
FROM base AS builder
WORKDIR /app

ARG DATABASE_URL
ENV DATABASE_URL=${DATABASE_URL}

COPY --from=installer /app/ .
COPY --from=pruner /app/out/full/ .

# Generate Prisma client
RUN bun run db:generate

RUN bun run build --filter=@unievent/server

# --- Runner Stage ---
FROM base AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000

# Copy necessary files from builder
COPY --from=builder /app/apps/server/dist ./apps/server/dist
COPY --from=builder /app/apps/server/package.json ./apps/server/package.json
# We still need node_modules for external dependencies not bundled by tsdown
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/apps/server/node_modules ./apps/server/node_modules

# Also copy prisma generated client if it's outside the bundle
COPY --from=builder /app/packages/db/prisma ./packages/db/prisma

EXPOSE 3000

# Use the mjs file generated by tsdown
CMD ["bun", "run", "apps/server/dist/index.mjs"]
