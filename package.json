{
	"name": "unievent",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"@types/bun": "^1.3.4",
			"react": "^19.2.3",
			"react-dom": "^19.2.3",
			"@prisma/client": "^7.2.0",
			"@types/react": "^19.2.10",
			"@types/react-dom": "^19.2.3"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"lint": "turbo lint",
		"check-types": "turbo check-types",
		"dev:web": "turbo -F @unievent/web dev",
		"dev:server": "turbo -F @unievent/server dev",
		"db:push": "turbo -F @unievent/db db:push",
		"db:studio": "turbo -F @unievent/db db:studio",
		"db:generate": "turbo -F @unievent/db db:generate",
		"db:migrate": "turbo -F @unievent/db db:migrate",
		"db:seed": "turbo -F @unievent/db db:seed",
		"format": "biome check --write .",
		"check": "bun run lint && bun run check-types",
		"check:ci": "bun run lint && bun run check-types && bun run build",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@types/bun": "catalog:",
		"@unievent/config": "workspace:*",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.2",
		"turbo": "^2.9.1",
		"typescript": "^6"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write"
		]
	},
	"packageManager": "bun@1.3.6",
	"engines": {
		"bun": ">=1.3.6",
		"node": ">=20"
	}
}
