{
	"name": "voltaze",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/web",
			"apps/server",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"@types/bun": "^1.3.4",
			"lucide-react": "^0.546.0",
			"next-themes": "^0.4.6",
			"react": "^19.2.3",
			"react-dom": "^19.2.3",
			"sonner": "^2.0.5",
			"@prisma/client": "^7.2.0",
			"@types/react": "^19.2.10",
			"@types/react-dom": "^19.2.3",
			"tailwindcss": "^4.1.18"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"db:push": "turbo -F @unievent/db db:push",
		"db:studio": "turbo -F @unievent/db db:studio",
		"db:generate": "turbo -F @unievent/db db:generate",
		"db:migrate": "turbo -F @unievent/db db:migrate",
		"db:seed": "turbo -F @unievent/db db:seed",
		"check": "biome check --write .",
		"prepare": "husky"
	},
	"dependencies": {
		"@unievent/env": "workspace:*",
		"dayjs": "^1.11.20",
		"dotenv": "catalog:",
		"html5-qrcode": "^2.3.8",
		"qrcode.react": "^4.2.0",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@types/bun": "catalog:",
		"@unievent/config": "workspace:*",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.2",
		"turbo": "^2.9.1",
		"typescript": "^6"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write"
		]
	},
	"packageManager": "bun@1.3.6"
}
